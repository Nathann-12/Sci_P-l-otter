grid.alpha: 0.28
axes.grid: True
axes.grid.which: major
axes.axisbelow: True
axes.xmargin: 0.02
axes.ymargin: 0.06
lines.linewidth: 2.0
lines.antialiased: True
lines.solid_capstyle: round
scatter.marker: o
legend.frameon: True
legend.fancybox: True
