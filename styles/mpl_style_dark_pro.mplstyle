axes.linewidth: 1.0
axes.spines.top: False
axes.spines.right: False
font.family: sans-serif
font.sans-serif: Noto Sans Thai, Sarabun, Segoe UI, Arial
axes.unicode_minus: False
axes.formatter.use_locale: False
axes.formatter.use_mathtext: False
axes.titlesize: 12
axes.labelsize: 11
xtick.labelsize: 10
ytick.labelsize: 10
legend.fontsize: 10
xtick.color: "#cfd3d6"
ytick.color: "#cfd3d6"
xtick.direction: in
ytick.direction: in
